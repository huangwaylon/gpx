  <metadata>
    <name><![CDATA[Snow Lake Trail]]></name>
    <desc><![CDATA[]]></desc>
    <link href="http://www.alltrails.com">
      <text>AllTrails, LLC</text>
    </link>
    <bounds minlat="47.44542" minlon="-121.44849" maxlat="47.46856" maxlon="-121.42282"/>
  </metadata>
  <wpt lat="47.4580417" lon="-121.4479646">
    <name><![CDATA[Optional side trip to Source Lake Overlook Trail]]></name>
    <desc><![CDATA[]]></desc>
  </wpt>
  <wpt lat="47.46011" lon="-121.44752">
    <name><![CDATA[Snow Lake Viewpoint]]></name>
    <desc><![CDATA[]]></desc>
  </wpt>
  <wpt lat="47.46411" lon="-121.44486">
    <name><![CDATA[Waterfall]]></name>
    <desc><![CDATA[Another great spot to stop and explore. If the water is low enough you can easily climb all the way to the top of the falls. The falls are prettiest just past the spot you can see from the bottom.]]></desc>
  </wpt>
  <wpt lat="47.46856" lon="-121.44812">
    <name><![CDATA[End of Snow Trail]]></name>
    <desc><![CDATA[This is the endpoint for this route. Continuing left at this junction will lead you to Gem Lake and eventually Wildcat Lakes. Turning right eventually takes you to the Middle Fork Trail via Rock Creek Trail.]]></desc>
  </wpt>
